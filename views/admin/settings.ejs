<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pengaturan - Admin Kios</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/tailwind.css">
</head>
<style>@media (max-width:767px){body{padding-bottom:64px}}</style>
<body class="bg-gray-50 font-[Plus_Jakarta_Sans]">
    <%- include('partials/navbar') %>
    <div class="max-w-3xl mx-auto px-4 py-8">
        <h1 class="text-2xl font-extrabold text-burgundy mb-6">Pengaturan Toko</h1>

        <% if (message) { %>
            <div class="mb-4 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-sm text-emerald-700"><%= message %></div>
        <% } %>
        <% if (error) { %>
            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"><%= error %></div>
        <% } %>

        <form method="POST" enctype="multipart/form-data" class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm space-y-4">
            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Nama Toko</label>
                <input type="text" name="store_name" value="<%= settings.store_name || '' %>" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy">
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Nomor WhatsApp</label>
                <input type="text" name="whatsapp_number" value="<%= settings.whatsapp_number || '' %>" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy">
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Alamat</label>
                <textarea name="store_address" rows="2" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy"><%= settings.store_address || '' %></textarea>
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Jam Operasional</label>
                <input type="text" name="store_hours" value="<%= settings.store_hours || '' %>" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy">
            </div>

            <div class="border-t border-gray-100 pt-4">
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" name="store_closed" <%= settings.store_closed === '1' ? 'checked' : '' %> class="w-5 h-5 text-burgundy border-gray-300 rounded focus:ring-burgundy">
                    <div>
                        <span class="text-sm font-bold text-gray-700">Toko Ditutup Sementara</span>
                        <p class="text-xs text-gray-400">Jika dicentang, pelanggan akan melihat toko sedang tutup dan tidak bisa order</p>
                    </div>
                </label>
            </div>

            <div class="border-t border-gray-100 pt-4">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Teks Pengumuman (tampil di halaman depan)</label>
                <textarea name="announcement_text" rows="3" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy"><%= settings.announcement_text || '' %></textarea>
                <p class="text-[10px] text-gray-400 mt-1">Kosongkan jika tidak ingin menampilkan pengumuman</p>
            </div>

            <div class="border-t border-gray-100 pt-4">
                <h3 class="text-sm font-bold text-burgundy mb-3">Pembayaran QRIS</h3>
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Nama QRIS (contoh: Kios Berkat Indah)</label>
                        <input type="text" name="qris_name" value="<%= settings.qris_name || '' %>" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Gambar QRIS</label>
                        <% if (settings.qris_image) { %>
                            <div class="mb-2">
                                <img src="<%= settings.qris_image %>" alt="QRIS" class="w-32 h-32 object-contain border border-gray-200 rounded-xl">
                            </div>
                        <% } %>
                        <input type="file" name="qris_image" accept="image/*" class="w-full text-sm">
                        <p class="text-[10px] text-gray-400 mt-1">Upload gambar QRIS untuk pembayaran (format PNG/JPG)</p>
                    </div>
                </div>
            </div>
            <button type="submit" class="bg-burgundy text-white font-bold py-2.5 px-6 rounded-xl text-sm hover:bg-opacity-90 transition-all">Simpan Pengaturan</button>
        </form>

        <div class="mt-8 bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
            <h2 class="text-lg font-extrabold text-burgundy mb-4">Ubah Password Admin</h2>
            <form method="POST" action="/admin/reset-password" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Password Lama</label>
                    <input type="password" name="current_password" required class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1">Password Baru (min. 6 karakter)</label>
                    <input type="password" name="new_password" required minlength="6" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm outline-none focus:ring-1 focus:ring-burgundy">
                </div>
                <button type="submit" class="bg-amber-600 hover:bg-amber-700 text-white font-bold py-2.5 px-6 rounded-xl text-sm transition-all">Ubah Password</button>
            </form>
        </div>
    </div>
</body>
</html>