<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Admin Kios</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/tailwind.css">
</head>
<style>
@media (max-width: 767px) {
    body { padding-bottom: 64px; }
    .stat-card { text-align: center; padding: 1rem 0.5rem; }
}
</style>
<body class="bg-gray-50 font-[Plus_Jakarta_Sans]">
    <%- include('partials/navbar') %>
    <div class="max-w-7xl mx-auto px-3 py-4 sm:px-4 sm:py-8">
        <!-- Quick Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-4 sm:mb-8">
            <a href="/admin/products" class="stat-card bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all active:scale-[0.97] block">
                <p class="text-2xl sm:text-3xl font-extrabold text-burgundy"><%= totalProducts %></p>
                <p class="text-xs sm:text-sm text-gray-500 font-bold mt-1">Produk</p>
            </a>
            <a href="/admin/orders" class="stat-card bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all active:scale-[0.97] block">
                <p class="text-2xl sm:text-3xl font-extrabold text-blue-600"><%= totalOrders %></p>
                <p class="text-xs sm:text-sm text-gray-500 font-bold mt-1">Pesanan</p>
            </a>
            <a href="/admin/orders?status=pending" class="stat-card bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all active:scale-[0.97] block relative">
                <p class="text-2xl sm:text-3xl font-extrabold text-amber-600"><%= pendingOrders %></p>
                <p class="text-xs sm:text-sm text-gray-500 font-bold mt-1">Menunggu</p>
                <% if (pendingOrders > 0) { %>
                    <span class="absolute top-2 right-2 w-3 h-3 bg-red-500 rounded-full animate-ping"></span>
                <% } %>
            </a>
            <a href="/admin/revenue" class="stat-card bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all active:scale-[0.97] block">
                <p class="text-lg sm:text-3xl font-extrabold text-emerald-600 truncate">Rp <%= totalRevenue.toLocaleString('id-ID') %></p>
                <p class="text-xs sm:text-sm text-gray-500 font-bold mt-1">Pendapatan</p>
            </a>
        </div>

        <!-- Action Cards -->
        <div class="grid grid-cols-2 gap-3 sm:gap-4 mb-4 sm:mb-8">
            <a href="/admin/orders?status=pending" class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all active:scale-[0.97] flex flex-col items-center gap-2 text-center">
                <div class="w-10 h-10 sm:w-14 sm:h-14 bg-red-100 rounded-xl flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <div>
                    <p class="text-base sm:text-xl font-extrabold text-red-600"><%= pendingOrders %> Baru</p>
                    <p class="text-[10px] sm:text-xs text-gray-500 font-semibold">Belum dicek</p>
                </div>
            </a>
            <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 border border-gray-100 shadow-sm flex flex-col items-center gap-2 text-center">
                <div class="w-10 h-10 sm:w-14 sm:h-14 <%= storeClosed === '1' ? 'bg-red-100' : 'bg-emerald-100' %> rounded-xl flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="<%= storeClosed === '1' ? '#dc2626' : '#059669' %>" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                    <p class="text-base sm:text-xl font-extrabold <%= storeClosed === '1' ? 'text-red-600' : 'text-emerald-600' %>"><%= storeClosed === '1' ? 'Toko Tutup' : 'Toko Buka' %></p>
                    <p class="text-[10px] sm:text-xs text-gray-500 font-semibold">Status</p>
                </div>
                <a href="/admin/settings" class="text-[10px] sm:text-xs font-semibold text-burgundy hover:underline">Ubah</a>
            </div>
        </div>

        <!-- Recent Orders -->
        <h2 class="font-bold text-gray-800 mb-3 sm:mb-4 flex items-center gap-2 text-sm sm:text-base">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Pesanan Terbaru
        </h2>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="divide-y divide-gray-100">
                <% if (recentOrders.length === 0) { %>
                    <div class="p-6 sm:p-8 text-center text-gray-400 text-xs sm:text-sm">Belum ada pesanan</div>
                <% } %>
                <% recentOrders.forEach(order => { %>
                    <a href="/admin/orders" class="flex items-center justify-between p-3 sm:p-4 hover:bg-gray-50 transition-colors active:bg-gray-100">
                        <div class="min-w-0 flex-1">
                            <p class="text-xs sm:text-sm font-bold text-gray-800 truncate"><%= order.order_number %></p>
                            <p class="text-[10px] sm:text-xs text-gray-500 truncate"><%= order.customer_name %></p>
                        </div>
                        <div class="text-right flex-shrink-0 ml-2">
                            <p class="text-xs sm:text-sm font-bold text-burgundy">Rp <%= order.total.toLocaleString('id-ID') %></p>
                            <span class="text-[9px] sm:text-xs font-bold px-1.5 sm:px-2.5 py-0.5 rounded-full inline-block
                                <%= order.status === 'pending' ? 'bg-amber-100 text-amber-700' :
                                   order.status === 'confirmed' ? 'bg-blue-100 text-blue-700' :
                                   order.status === 'processing' ? 'bg-purple-100 text-purple-700' :
                                   order.status === 'ready' ? 'bg-emerald-100 text-emerald-700' :
                                   'bg-green-100 text-green-700' %>">
                                <%= order.status.toUpperCase() %>
                            </span>
                        </div>
                    </a>
                <% }) %>
            </div>
        </div>
    </div>
    <script>lucide.createIcons()</script>
</body>
</html>