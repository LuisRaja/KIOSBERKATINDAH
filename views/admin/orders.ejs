<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pesanan - Admin Kios</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-gray-50 font-[Plus_Jakarta_Sans]">
    <%- include('partials/navbar') %>
    <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-extrabold text-burgundy">Pesanan</h1>
            <div class="flex gap-1 flex-wrap">
                <% 
                const tabs = [
                    { key: '', label: 'Semua', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
                    { key: 'pending', label: 'Baru', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
                    { key: 'processing', label: 'Proses', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
                    { key: 'ready', label: 'Siap', icon: 'M5 13l4 4L19 7' },
                    { key: 'completed', label: 'Selesai', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
                ];
                %>
                <% tabs.forEach(t => { %>
                    <a href="?status=<%= t.key %>" class="flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg transition-all <%= (currentStatus === t.key) ? 'bg-burgundy text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50' %>">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="<%= t.icon %>"/></svg>
                        <%= t.label %>
                        <% if (t.key === 'pending') { %>
                            <span id="pending-count" class="bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center"><%= orders.filter(o => o.status === 'pending').length %></span>
                        <% } %>
                    </a>
                <% }) %>
            </div>
        </div>

        <div class="space-y-3">
            <% if (orders.length === 0) { %>
                <div class="bg-white rounded-2xl p-12 text-center text-gray-400 border border-gray-100 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mx-auto mb-3 text-gray-300"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <p class="font-semibold">Belum ada pesanan</p>
                </div>
            <% } %>
            <% orders.forEach(order => { %>
                <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all <%= order.status === 'pending' ? 'ring-2 ring-amber-300 ring-opacity-50' : '' %>">
                    <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
                        <div class="flex items-center gap-2">
                            <% if (order.status === 'pending') { %>
                                <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
                            <% } %>
                            <span class="font-bold text-gray-800"><%= order.order_number %></span>
                            <span class="text-xs text-gray-400"><%= new Date(order.created_at).toLocaleString('id-ID') %></span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-bold px-2.5 py-1 rounded-full 
                                <%= order.status === 'pending' ? 'bg-red-100 text-red-700' :
                                   order.status === 'processing' ? 'bg-purple-100 text-purple-700' :
                                   order.status === 'ready' ? 'bg-emerald-100 text-emerald-700' :
                                   order.status === 'completed' ? 'bg-green-100 text-green-700' :
                                   order.status === 'cancelled' ? 'bg-gray-100 text-gray-600' :
                                   'bg-gray-100 text-gray-600' %>">
                                <%= order.status === 'pending' ? 'BARU' : order.status.toUpperCase() %>
                            </span>
                            <span class="text-xs font-bold px-2.5 py-1 rounded-full
                                <%= order.payment_status === 'paid' ? 'bg-green-100 text-green-700' :
                                   order.payment_status === 'pending' ? 'bg-amber-100 text-amber-700' :
                                   'bg-gray-100 text-gray-600' %>">
                                <%= order.payment_status === 'paid' ? 'LUNAS' : order.payment_status.toUpperCase() %>
                            </span>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-5 gap-2 text-xs mb-3">
                        <div><span class="text-gray-400">Pelanggan:</span> <span class="font-semibold text-gray-700"><%= order.customer_name %></span></div>
                        <div><span class="text-gray-400">Telepon:</span> <span class="font-semibold text-gray-700"><%= order.customer_phone %></span></div>
                        <div><span class="text-gray-400">Email/User:</span> <span class="font-semibold text-gray-700"><%= order.user_email || '-' %></span></div>
                        <div><span class="text-gray-400">Ambil:</span> <span class="font-semibold text-gray-700"><%= order.pickup_date %> <%= order.pickup_time %></span></div>
                        <div><span class="text-gray-400">Total:</span> <span class="font-semibold text-burgundy">Rp <%= order.total.toLocaleString('id-ID') %></span></div>
                    </div>
                    <% if (order.notes) { %>
                        <div class="mb-2 p-2 bg-gray-50 rounded-lg text-xs text-gray-600"><span class="font-semibold">Catatan:</span> <%= order.notes %></div>
                    <% } %>
                    <div class="border-t border-gray-100 pt-3">
                        <table class="w-full text-xs">
                            <thead class="text-gray-400">
                                <tr><th class="text-left pb-1">Produk</th><th class="text-center pb-1">Qty</th><th class="text-right pb-1">Harga</th><th class="text-right pb-1">Subtotal</th></tr>
                            </thead>
                            <tbody>
                                <% (order.items || []).forEach(item => { %>
                                    <tr class="border-t border-gray-50">
                                        <td class="py-1.5 font-semibold text-gray-700"><%= item.product_name %></td>
                                        <td class="py-1.5 text-center text-gray-500"><%= item.quantity %></td>
                                        <td class="py-1.5 text-right text-gray-500">Rp <%= item.product_price.toLocaleString('id-ID') %></td>
                                        <td class="py-1.5 text-right font-semibold text-gray-700">Rp <%= item.subtotal.toLocaleString('id-ID') %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <div class="border-t border-gray-100 pt-3 mt-2 flex flex-wrap items-center justify-between gap-2">
                        <div class="flex items-center gap-2">
                            <% if (order.status === 'pending') { %>
                                <button onclick="moveStatus(<%= order.id %>, 'processing')" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-burgundy text-white hover:bg-opacity-90 transition-all flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                                    Terima Pesanan
                                </button>
                            <% } %>
                            <% if (order.status === 'processing') { %>
                                <button onclick="moveStatus(<%= order.id %>, 'ready')" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-purple-600 text-white hover:bg-opacity-90 transition-all flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                                    Siap Diambil
                                </button>
                            <% } %>
                            <% if (order.status === 'ready') { %>
                                <button onclick="moveStatus(<%= order.id %>, 'completed')" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-emerald-600 text-white hover:bg-opacity-90 transition-all flex items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                    Selesai
                                </button>
                            <% } %>
                            <% if (order.payment_status !== 'paid' && order.status !== 'cancelled') { %>
                                <button onclick="markPaid(<%= order.id %>)" class="text-xs font-bold px-2.5 py-1.5 rounded-lg bg-amber-100 text-amber-700 hover:bg-amber-200 transition-all">
                                    <%= order.status === 'completed' ? 'Masukkan Cash' : 'Tandai Dibayar' %>
                                </button>
                            <% } %>
                            <% if (order.status !== 'completed' && order.status !== 'cancelled') { %>
                                <button onclick="moveStatus(<%= order.id %>, 'cancelled')" class="text-xs font-bold px-2.5 py-1.5 rounded-lg bg-red-100 text-red-700 hover:bg-red-200 transition-all">Batalkan</button>
                            <% } %>
                        </div>
                        <div class="flex items-center gap-2">
                            <% if (order.payment_proof) { %>
                                <a href="<%= order.payment_proof %>" target="_blank" class="text-xs font-bold px-2.5 py-1.5 rounded-lg bg-purple-100 text-purple-700 hover:bg-purple-200 transition-all">Lihat Bukti</a>
                            <% } %>
                            <a href="/admin/orders/<%= order.id %>/nota" target="_blank" class="text-xs font-bold px-2.5 py-1.5 rounded-lg bg-blue-100 text-blue-700 hover:bg-blue-200 transition-all">Nota</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <script>
        lucide.createIcons();

        async function moveStatus(id, status) {
            const labels = { processing: 'Terima pesanan ini?', ready: 'Tandai siap diambil?', completed: 'Selesaikan pesanan?', cancelled: 'Batalkan pesanan?' };
            if (!confirm(labels[status] || 'Ubah status?')) return;
            const res = await fetch('/admin/orders/' + id + '/status', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            const data = await res.json();
            if (data.success) location.reload();
            else alert('Gagal: ' + (data.error || ''));
        }

        async function markPaid(id) {
            if (!confirm('Tandai pesanan ini sebagai LUNAS?')) return;
            const res = await fetch('/admin/orders/' + id + '/pay', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();
            if (data.success) location.reload();
            else alert('Gagal: ' + (data.error || ''));
        }

        // Auto-refresh untuk cek orderan baru setiap 15 detik
        let lastCount = <%= orders.filter(o => o.status === 'pending').length %>;
        setInterval(async () => {
            try {
                const res = await fetch('/admin/api/pending-count');
                const data = await res.json();
                if (data.count > lastCount) {
                    new Notification('Pesanan Baru!', { body: data.count + ' pesanan menunggu' });
                    location.reload();
                }
                lastCount = data.count;
            } catch(e) {}
        }, 15000);
    </script>
</body>
</html>