<%
var navLinks = [
    { href: '/admin', label: 'Dashboard', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
    { href: '/admin/orders', label: 'Pesanan', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01' },
    { href: '/admin/products', label: 'Produk', icon: 'M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0' },
    { href: '/admin/revenue', label: 'Pendapatan', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
    { href: '/admin/settings', label: 'Atur', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
    { href: '/admin/users', label: 'User', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z' },
];
%>
<nav class="bg-burgundy text-white sticky top-0 z-50 shadow-md">
    <div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/admin" class="font-bold tracking-tight text-gold text-sm flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Kios Admin
        </a>
        <div class="hidden md:flex items-center gap-1">
            <% navLinks.forEach(function(link) { %>
                <a href="<%= link.href %>" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg hover:bg-white hover:bg-opacity-10 transition-colors text-xs font-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="<%= link.icon %>"/></svg>
                    <%= link.label %>
                </a>
            <% }); %>
        </div>
        <div class="flex items-center gap-3">
            <span class="text-xs text-gray-300 hidden sm:inline"><%= admin?.username || 'Admin' %></span>
            <a href="/" class="text-xs text-gray-300 hover:text-white transition-colors">Toko</a>
            <a href="/admin/logout" class="text-xs bg-white bg-opacity-10 px-3 py-1.5 rounded-lg hover:bg-opacity-20 transition-colors">Logout</a>
        </div>
    </div>
</nav>
<!-- Mobile bottom tab bar -->
<div class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-burgundy border-t border-white border-opacity-10 safe-area-bottom">
    <div class="flex items-center justify-around">
        <% navLinks.forEach(function(link) { %>
            <a href="<%= link.href %>" class="flex flex-col items-center gap-0.5 py-1.5 px-1 min-w-0 flex-1 text-white text-opacity-70">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="<%= link.icon %>"/></svg>
                <span class="text-[9px] font-bold truncate w-full text-center"><%= link.label %></span>
            </a>
        <% }); %>
    </div>
</div>
<style>
.safe-area-bottom { padding-bottom: env(safe-area-inset-bottom, 0px); }
</style>
<script>
(function() {
    var path = window.location.pathname;
    document.querySelectorAll('.md\\:hidden a').forEach(function(a) {
        var href = a.getAttribute('href');
        if (href === '/admin' && path === '/admin') {
            a.classList.remove('text-white', 'text-opacity-70');
            a.classList.add('text-gold');
        } else if (href !== '/admin' && path.startsWith(href)) {
            a.classList.remove('text-white', 'text-opacity-70');
            a.classList.add('text-gold');
        }
    });
})();
</script>