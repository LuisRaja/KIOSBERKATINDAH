{
  "name": "kios-berkat-indah",
  "version": "2.0.0",
  "description": "E-commerce digital untuk Kios Berkat Indah",
  "main": "server.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/input.css -o ./public/css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i ./src/input.css -o ./public/css/tailwind.css --watch",
    "start": "npm run build:css && node server.js",
    "dev": "node --watch server.js",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:assets": "npx @capacitor/assets generate --iconBackgroundColor '#f0e9e1' --iconBackgroundColorDark '#f0e9e1' --splashBackgroundColor '#f0e9e1' --splashBackgroundColorDark '#f0e9e1'",
    "cap:build": "npm run cap:assets && npx cap copy && npx cap sync"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.3.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "tailwindcss": "^3.4.19"
  }
}
